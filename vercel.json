{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/webhook/(.*)", "destination": "/api/index" }
  ],
  "outputDirectory": "public",
  "functions": {
    "api/index.js": {
      "maxDuration": 10
    }
  },
  "routes": [
    { "src": "/api(.*)", "dest": "/api/index.js" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}